# ── Stage 1: Build React frontend ─────────────────────────────────────────
FROM node:20-alpine AS frontend-builder
WORKDIR /build
COPY frontend/package.json .
RUN npm install --frozen-lockfile
COPY frontend/ .
RUN npm run build

# ── Stage 2: Production image ──────────────────────────────────────────────
FROM python:3.11-slim

# WHISPER_MODEL build arg lets you bake a specific model size into the image.
# Supported: tiny | base | small | medium | large-v2 | large-v3
# Larger = better accuracy, bigger image, more RAM needed.
#   tiny   → ~75 MB model  | 1 GB RAM
#   base   → ~145 MB model | 1.5 GB RAM  (default — good balance for Cloud Run free tier)
#   small  → ~465 MB model | 2 GB RAM
#   medium → ~1.5 GB model | 4 GB RAM
ARG WHISPER_MODEL=base
ENV WHISPER_MODEL=${WHISPER_MODEL}

# System packages: nginx, supervisor (process manager), gettext (envsubst for PORT)
RUN apt-get update && apt-get install -y --no-install-recommends \
        nginx \
        supervisor \
        gettext-base \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Python dependencies
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Pre-download the Whisper model during image build so there is no download
# on first request (avoids Cloud Run request timeouts on cold starts).
RUN python - <<'EOF'
import os, sys
from faster_whisper import WhisperModel
model = os.environ["WHISPER_MODEL"]
print(f"Pre-downloading Whisper model: {model}", flush=True)
WhisperModel(model, device="cpu", compute_type="int8")
print("Model ready.", flush=True)
EOF

# Backend source
COPY backend/main.py .

# React production build (served by nginx as static files)
COPY --from=frontend-builder /build/dist /app/static

# ── Runtime config ─────────────────────────────────────────────────────────

# nginx: listens on $PORT (Cloud Run injects this; default 8080).
# Serves /app/static for everything except /api/*, which is proxied to
# uvicorn on 127.0.0.1:8001.
COPY nginx.cloudrun.conf /etc/nginx/conf.d/default.conf.template

# Remove default nginx site so our config is the only one loaded.
RUN rm -f /etc/nginx/sites-enabled/default /etc/nginx/conf.d/default.conf

# supervisord: manages both nginx and uvicorn as child processes.
COPY supervisord.cloudrun.conf /etc/supervisor/conf.d/voiceagent.conf

# Entrypoint: substitute $PORT into nginx config, then start supervisord.
COPY start-cloudrun.sh /start.sh
RUN chmod +x /start.sh

# Cloud Run sets PORT; default to 8080 so the image works locally too.
ENV PORT=8080

EXPOSE 8080

CMD ["/start.sh"]
